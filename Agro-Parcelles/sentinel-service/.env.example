# Copiez ce fichier en .env (ou exportez ces variables) et renseignez vos valeurs.
# La clé JSON du compte de service ne doit JAMAIS être committée (voir .gitignore).

# Id du projet Google Cloud où l'API Earth Engine est activée
GEE_PROJECT=mon-projet-gee

# Email du compte de service
GEE_SERVICE_ACCOUNT=agro-sentinel@mon-projet-gee.iam.gserviceaccount.com

# Chemin du fichier JSON de la clé du compte de service
# En local : ./secrets/gee-key.json   |   En Docker (compose) : /secrets/gee-key.json
GEE_PRIVATE_KEY_FILE=./secrets/gee-key.json
